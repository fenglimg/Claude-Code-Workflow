  "data_flow": {
    "diagram": "UserInput → RequirementsCollection → WorkflowDocumentInput → PhaseDecomposition → SimilarWorkflowAnalysis → OutlineGeneration → ComponentScaffolding → ClosureValidation → WorkflowPackage",
    "stages": [
      {"stage": "RequirementsCollection", "input": "User answers", "output": "workflow-config.json", "component": "Phase 1"},
      {"stage": "WorkflowDocumentInput", "input": "User text/file", "output": "workflow-document.json", "component": "Phase 2"},
      {"stage": "PhaseDecomposition", "input": "workflow-document.json", "output": "phase-decomposition.json", "component": "Phase 3"},
      {"stage": "SimilarWorkflowAnalysis", "input": "phase-decomposition.json + codebase", "output": "similarity-analysis.json", "component": "Phase 4"},
      {"stage": "OutlineGeneration", "input": "phase-decomposition.json + similarity-analysis.json", "output": "workflow-outline.json", "component": "Phase 5"},
      {"stage": "ComponentScaffolding", "input": "workflow-outline.json", "output": "Generated files", "component": "Phase 6"},
      {"stage": "ClosureValidation", "input": "Generated files + workflow-config.json", "output": "closure-validation-report.json", "component": "Phase 7"}
    ],
    "dependencies": ["mcp__ace-tool__search_context", "skill-generator (optional)", "existing workflow files for pattern extraction"]
  },
  "design_decisions": [
    {
      "decision": "采用7阶段顺序执行模式",
      "rationale": "新增流程输入、Phase拆解、相似流程分析阶段以满足用户需求",
      "tradeoff": "流程更长，但功能更完整"
    },
    {
      "decision": "使用ACE-tool进行相似流程分析",
      "rationale": "语义搜索比关键词搜索更准确，能找到真正相似的实现",
      "tradeoff": "依赖ACE-tool可用性"
    },
    {
      "decision": "增加闭环验证阶段",
      "rationale": "确保生成的工作流能完整实现用户需求，避免遗漏",
      "tradeoff": "增加执行时间，但提高质量"
    },
    {
      "decision": "支持流程文档输入",
