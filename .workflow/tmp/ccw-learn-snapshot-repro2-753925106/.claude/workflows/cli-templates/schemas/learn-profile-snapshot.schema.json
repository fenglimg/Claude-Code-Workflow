{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learn Profile Snapshot",
  "description": "Derived read model folded deterministically from append-only profile events.",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "profile_id": { "type": "string" },
    "version": { "type": "integer", "minimum": 0 },
    "updated_at": {
      "anyOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "pre_context": {
      "anyOf": [
        { "type": "object", "additionalProperties": true },
        { "type": "null" }
      ]
    },
    "skills": {
      "type": "object",
      "properties": {
        "asserted": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "inferred": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      },
      "required": ["asserted", "inferred"],
      "additionalProperties": true
    },
    "_metadata": { "type": "object", "additionalProperties": true }
  },
  "required": ["profile_id", "version", "skills"],
  "additionalProperties": true
}
