{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learn Workflow Plan",
  "description": "Defines the structure of a learning plan, composed of a DAG of knowledge points.",
  "type": "object",
  "properties": {
    "session_id": { "type": "string" },
    "learning_goal": { "type": "string" },
    "profile_id": { "type": "string" },
    "phases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "properties": {
          "phase_number": { "type": "integer", "minimum": 1 },
          "phase_name": { "type": "string" },
          "knowledge_point_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^KP-\\d+$" }
          },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "active", "completed"] }
        },
        "required": ["phase_number", "phase_name", "knowledge_point_ids", "description", "status"]
      }
    },
    "knowledge_points": {
      "type": "array",
      "maxItems": 15,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^KP-\\d+$" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "prerequisites": { "type": "array", "items": { "type": "string" } },
          "topic_refs": { "type": "array", "items": { "type": "string" } },
          "resources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "url": { "type": "string", "format": "uri" },
                "summary": { "type": "string" },
                "quality": { "type": "string", "enum": ["gold", "silver", "bronze"] }
              },
              "required": ["type", "url", "quality"]
            }
          },
          "assessment": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["practical_task", "code_challenge", "multiple_choice"] },
              "description": { "type": "string" },
              "acceptance_criteria": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["type", "description"]
          },
          "phase": { "type": "integer", "minimum": 1 },
          "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "skipped", "optional"] }
        },
        "required": ["id", "title", "prerequisites", "resources", "assessment", "phase", "status"]
      }
    },
    "dependency_graph": {
      "type": "object",
      "properties": {
        "nodes": { "type": "array", "items": { "type": "string" } },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" }
            },
            "required": ["from", "to"]
          }
        }
      },
      "required": ["nodes", "edges"]
    },
    "_metadata": { "type": "object" }
  },
  "required": ["session_id", "learning_goal", "phases", "knowledge_points", "dependency_graph"]
}
